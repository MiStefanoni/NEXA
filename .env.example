# Nodemailer SMTP configuration
# Use either SMTP_SERVICE or SMTP_HOST.

# Example for Gmail / Google Workspace:
# SMTP_SERVICE=gmail

# Example for a custom SMTP provider:
# SMTP_HOST=smtp.example.com

SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="Nexa <your-email@example.com>"

# Optional recipients for internal form submissions
APPLICATION_RECIPIENT=mifstefanoni@gmail.com
WAITLIST_RECIPIENT=mifstefanoni@gmail.com

# Admin authentication
# Set either ADMIN_PASSWORD for a plain password in local development
# or ADMIN_PASSWORD_HASH for a bcrypt hash in shared/production environments.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-admin-password
# ADMIN_PASSWORD_HASH=$2b$12$replace-with-bcrypt-hash

# Public site URL used in invitation emails
NEXT_PUBLIC_SITE_URL=https://www.onlinenexa.com
